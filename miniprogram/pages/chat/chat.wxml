<view class="page">
  <view class="top-bar" style="padding-top: {{statusBarHeight}}px">
    <view class="top-back" bindtap="onBack">
      <text class="back-arrow">←</text>
    </view>
    <text class="top-label">{{timePeriod}} {{timeClock}}</text>
  </view>

  <scroll-view scroll-y class="msg-area" scroll-with-animation
               scroll-into-view="{{scrollAnchor}}">
    <view class="msg-empty" wx:if="{{messages.length === 0}}">
      <text class="msg-empty-text">还没有人开口。</text>
    </view>
    <view class="msg-list" wx:else>
      <view class="msg-item" wx:for="{{messages}}" wx:key="id"
            style="animation-delay: {{index * 0.8}}s">
        <view class="msg-line"></view>
        <view class="msg-body">
          <text class="msg-content">{{item.content}}</text>
          <text class="msg-time">{{item.time}}</text>
        </view>
      </view>
    </view>
    <view id="bottom" style="height: 40rpx;"></view>
  </scroll-view>

  <view class="input-bar" style="padding-bottom: {{safeBottom}}px; bottom: {{keyboardHeight}}px">
    <view class="input-wrap">
      <input class="msg-input"
             placeholder="写点什么..."
             placeholder-style="color:rgba(0,0,0,0.15)"
             value="{{inputText}}"
             bindinput="onInput"
             confirm-type="send"
             bindconfirm="onSend"
             maxlength="500"
             adjust-position="{{false}}"/>
    </view>
    <button class="send-btn {{inputText ? 'send-active' : ''}}"
            bindtap="onSend">扔</button>
  </view>
</view>
