.page {
  position: relative;
  height: 100vh;
  background-color: #F5F3F0;
  overflow: hidden;
}

/* ====== 顶栏 ====== */

.top-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 2;
  display: flex;
  align-items: center;
  padding: 0 32rpx 20rpx;
  background-color: #F5F3F0;
}

.top-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  font-size: 32rpx;
  color: rgba(0, 0, 0, 0.25);
  font-weight: 200;
}

.top-label {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  font-weight: 300;
  color: rgba(0, 0, 0, 0.30);
  letter-spacing: 2rpx;
  margin-right: 60rpx;
}

/* ====== 空状态 ====== */

.msg-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
}

.msg-empty-text {
  font-size: 26rpx;
  font-weight: 300;
  color: rgba(0, 0, 0, 0.20);
  letter-spacing: 2rpx;
}

/* ====== 消息区 ====== */

.msg-area {
  position: fixed;
  top: 0;
  bottom: 0;
  left: 0;
  right: 0;
  padding-top: 160rpx;
  padding-bottom: 180rpx;
}

.msg-list {
  padding: 0 64rpx;
}

.msg-item {
  display: flex;
  margin-bottom: 110rpx;
  opacity: 0;
  animation: msgRise 2.0s ease-out forwards;
}

.msg-line {
  flex-shrink: 0;
  width: 1rpx;
  background-color: rgba(0, 0, 0, 0.08);
  margin-right: 24rpx;
  align-self: stretch;
}

.msg-body {
  flex: 1;
  max-width: 480rpx;
}

.msg-content {
  font-size: 30rpx;
  font-weight: 300;
  color: rgba(0, 0, 0, 0.55);
  line-height: 1.8;
  letter-spacing: 1rpx;
  word-break: break-all;
}

.msg-time {
  display: block;
  margin-top: 16rpx;
  font-size: 20rpx;
  font-weight: 300;
  color: rgba(0, 0, 0, 0.22);
  letter-spacing: 2rpx;
}

/* ====== 输入栏 ====== */

.input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 2;
  display: flex;
  align-items: center;
  padding: 20rpx 40rpx;
  background-color: #F5F3F0;
  border-top: 1rpx solid rgba(0, 0, 0, 0.08);
}

.input-wrap {
  flex: 1;
  margin-right: 24rpx;
}

.msg-input {
  width: 100%;
  height: 72rpx;
  padding: 0;
  background: transparent;
  color: rgba(0, 0, 0, 0.55);
  font-size: 28rpx;
  font-weight: 300;
}

.send-btn {
  flex-shrink: 0;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  background: transparent;
  border: 0;
  font-size: 28rpx;
  font-weight: 300;
  color: rgba(0, 0, 0, 0.20);
  line-height: 1;
}

.send-btn::after {
  border: 0;
}

.send-active {
  color: rgba(107, 94, 82, 0.65);
}

/* ====== 动画 ====== */

@keyframes msgRise {
  from {
    opacity: 0.15;
    transform: translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
